{
  "buildCommand": "npm run build",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node"
    },
    "api/search.ts": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/search",
      "destination": "/api/search"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/api/index"
    }
  ]
}
